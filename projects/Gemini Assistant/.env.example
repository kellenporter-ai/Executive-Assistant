# Gemini Executive Assistant — Environment Variables
# Copy this file to .env and fill in the values you need.
# All integrations are optional — the EA works without them.

# ─── Google Workspace (Gmail + Calendar) ───────────────────────────
# Choose ONE auth method:

# Option A: Service Account (headless, no browser needed)
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# Option B: OAuth Client Secret (opens browser on first use)
# GOOGLE_CLIENT_SECRET_FILE=/path/to/client-secret.json

# Tokens are stored in ~/.config/gemini-ea/tokens/ (never in the repo).

# ─── Web Research ──────────────────────────────────────────────────
# Optional — Gemini's built-in search works without this.
# Get a key at https://tavily.com (free tier available)
# TAVILY_API_KEY=tvly-xxxxx

# ─── Session Tracking ─────────────────────────────────────────────
# Set automatically by the Gemini CLI. Do not set manually.
# GEMINI_SESSION_ID=
